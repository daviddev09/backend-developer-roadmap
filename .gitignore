# ==========================================
# 1. ИЗОЛЯЦИЯ ОКРУЖЕНИЯ И ЗАВИСИМОСТЕЙ
# ==========================================
# Игнорируем папку виртуального окружения. Она весит много и не нужна на GitHub.
.venv/
venv/
ENV/

# ==========================================
# 2. КРИТИЧЕСКАЯ БЕЗОПАСНОСТЬ (СЕКРЕТЫ)
# ==========================================
# Игнорируем файлы, содержащие реальные пароли, токены ботов и ключи API.
.env
.env.local
.env.*.local
*.env

# Игнорируем файлы локальных баз данных
*.db
*.sqlite3

# ==========================================
# 3. СИСТЕМНЫЙ МУСОР PYTHON
# ==========================================
# Игнорируем кэш компиляции Python. Эти папки создаются автоматически при запуске скриптов.
__pycache__/
*.py[cod]
*$py.class

# ==========================================
# 4. НАСТРОЙКИ СРЕДЫ РАЗРАБОТКИ (IDE)
# ==========================================
# Игнорируем локальные настройки VS Code (цвета, история окон, конфигурации запуска)
.vscode/
.idea/

# ==========================================
# 5. ОПЕРАЦИОННАЯ СИСТЕМА
# ==========================================
# Игнорируем служебные файлы Windows (кэш эскизов папок)
Thumbs.db
desktop.ini